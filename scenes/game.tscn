theme_override_font_sizes/normal_font_size = 32
text = "Erica
•	Age of Death: 90
•	Cause of Death: Old age, dear
•	Likes: Crosswords, antiques, fashion, romance novels, my former work as an engineer.
•	Dislikes: Retirement was not kind, and I hate those feathered fiends.
"

[node name="Page5" type="RichTextLabel" parent="DossierPanel" unique_id=1076706079 groups=["dossierPages"]]
visible = false
layout_mode = 0
