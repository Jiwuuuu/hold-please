[sub_resource type="Resource" id="Resource_puzzle1"]
script = ExtResource("7_pdef")
title = "Night 1"
task_text = "[b]Night 1[/b]
Listening tonight:   1 Irene    2 Charles    3 Annabeth    4 Dafne

Caller 1: [garble]“I want to reach my late mother. I miss her most around Christmas.”[/garble]

[i]Grab the ringing jack's plug, carry it to the right listener's socket, then press the big button.[/i]"
callers = 1
listening = Array[String](["Irene", "Charles", "Annabeth", "Dafne"])
caller_lines = Array[String](["seeking a late mother, missed most at Christmas"])
solution = Array[String](["DD01", "XXXX", "XXXX", "XXXX"])
vignette_rows = Array[String](["…Mom?", "Evelyn? My little girl! How are the children? And your father?", "The kids are well, they often ask about you. Dad… we don’t really talk.", "I see, I don’t blame you. Still, let’s focus on the children today, we don’t have much time."])
hints = Array[String](["She misses her mother most at Christmas — which listener lived for family gatherings and snowmen?"])

[sub_resource type="Resource" id="Resource_puzzle2"]
script = ExtResource("7_pdef")
title = "Night 2"
task_text = "[b]Night 2[/b]
Listening tonight:   1 Irene    2 Charles    3 Annabeth    4 Dafne

Caller 1: [garble]“My sister has to hear this: we always knew the neighbours were hiding something!”[/garble]
Caller 2: [garble]“My aunt and I never mended things. Maybe now she will finally talk to me.”[/garble]

[i]Two callers tonight. Leave the other sockets empty. Wrong plug? Interact a connected socket to pull the line back out.[/i]"
callers = 2
listening = Array[String](["Irene", "Charles", "Annabeth", "Dafne"])
caller_lines = Array[String](["a sister — the neighbours were hiding something!", "an estranged aunt, ties to mend"])
solution = Array[String](["CC01", "AA02", "XXXX", "XXXX"])
vignette_rows = Array[String](["You won’t believe it! The young couple next door…", "Won’t believe? I knew it! I always knew it!", "Alright, alright, don’t gloat too much.", "Oh, I’ll gloat plenty. I always knew, and you naysayers called me a hag!"])
hints = Array[String](["Two sisters who always knew about the neighbours — which listener loved gossip?", "Caller 2 seeks an estranged aunt — rule out the gentleman and the gossip, then think of who’d keep a call short."])

[sub_resource type="Resource" id="Resource_puzzle3"]
script = ExtResource("7_pdef")
title = "Night 3"
task_text = "[b]Night 3[/b]
Listening tonight:   1 Bryan    2 Dafne    3 Gordon    4 Kevin

Caller 1: [garble]“My friend died so young, so suddenly. I need their voice again.”[/garble]
Caller 2: [garble]“There will be a rock concert in our friend's honour. Not their favourite — but they would love it.”[/garble]
Caller 3: [garble]“The whole team wants to say goodbye to our quarterback.”[/garble]
Caller 4: [garble]“I inherited the most wonderful old vinyls. I want to thank their careful owner.”[/garble]

[i]Full board. Lines must not tangle on the floor — hook a line through an anchor post to lift it over another.[/i]"
callers = 4
listening = Array[String](["Bryan", "Dafne", "Gordon", "Kevin"])
caller_lines = Array[String](["a friend lost young and suddenly", "a music lover — rock concert in their honour", "the team's quarterback", "a careful collector of old vinyls"])
solution = Array[String](["CC01", "DD02", "AA03", "BB04"])
vignette_rows = Array[String](["A rock concert, uh?", "Well, you were quite the rock-star, once upon a time…", "Surely, you jest, I can hardly remember having an audience of more than ten!", "Still, you taught half those kids. Or their parents.", "Was I so old?", "And wise!"])
hints = Array[String](["A sudden, tragic loss, still raw — which listener never saw the car coming?", "A rock concert in their honour — rock isn’t quite their thing, but who loved music of every kind?", "The team’s quarterback — which listener loved football?", "A careful collector of old vinyls — which listener adored Verdi?"])

