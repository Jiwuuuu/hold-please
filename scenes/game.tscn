theme_override_font_sizes/normal_font_size = 40
text = "Irene
•	Age of Death: 75
•	Cause of Death: Cancer
•	Likes: Chai, classical music, my cats: I hope they’re looked after.
•	Dislikes: Long, pointless conversations, screaming children, loud noises.
"

[node name="Page9" type="RichTextLabel" parent="DossierPanel" groups=["dossierPages"]]
