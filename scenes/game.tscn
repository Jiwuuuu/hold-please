theme_override_font_sizes/normal_font_size = 32
text = "Dafne
•	Age of Death: 47
•	Cause of Death: Freak accident, a tragedy
•	Likes: Verdi, snowmen, lemonade and family gatherings.
•	Dislikes: Being dead, actually. Also, not a big reader nor a fan of sports.
"

[node name="Page4" type="RichTextLabel" parent="DossierPanel" unique_id=1235445016 groups=["dossierPages"]]
