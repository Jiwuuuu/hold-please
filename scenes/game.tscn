offset_right = 1131.0
offset_bottom = 608.0
theme_override_font_sizes/normal_font_size = 40
text = "Annabeth
•	Age of Death: A lady never tells.
•	Cause of Death: Heart failure.
•	Likes: Fine wine, gossip and jazz music.
•	Dislikes: Pets and cold weather. Also, I never understood people who drink tea.
"

[node name="Page1" type="RichTextLabel" parent="DossierPanel" groups=["dossierPages"]]
visible = false
layout_mode = 0
offset_left = 96.0
offset_top = 74.0
offset_right = 1131.0
offset_bottom = 608.0
theme_override_font_sizes/normal_font_size = 40
text = "Bryan
•	Age of Death: 52
•	Cause of Death: Severe alcohol poisoning.
•	Likes: Booze, chess and football. And my family, of course!
•	Dislikes: Rock and roll and those blasted politics.

"

[node name="Page2" type="RichTextLabel" parent="DossierPanel" groups=["dossierPages"]]
visible = false
layout_mode = 0
offset_left = 96.0
offset_top = 74.0
offset_right = 1131.0
offset_bottom = 608.0
theme_override_font_sizes/normal_font_size = 40
text = "Charles
•	Age of Death: 81
•	Cause of Death: Severe concussion
•	Likes: Checkers, charity work, and my pet parrot.
•	Dislikes: Classical music, opera, ballet and all that. And oranges! Nasty oranges!
"

[node name="Page3" type="RichTextLabel" parent="DossierPanel" groups=["dossierPages"]]
visible = false
layout_mode = 0
offset_left = 96.0
offset_top = 74.0
offset_right = 1131.0
offset_bottom = 608.0
theme_override_font_sizes/normal_font_size = 40
text = "Dafne
•	Age of Death: 47
•	Cause of Death: Freak accident, a tragedy
•	Likes: Verdi, snowmen, lemonade and family gatherings.
•	Dislikes: Being dead, actually. Also, not a big reader nor a fan of sports.
"

[node name="Page4" type="RichTextLabel" parent="DossierPanel" groups=["dossierPages"]]
visible = false
layout_mode = 0
offset_left = 96.0
offset_top = 74.0
offset_right = 1131.0
offset_bottom = 608.0
theme_override_font_sizes/normal_font_size = 40
text = "Erica
•	Age of Death: 90
•	Cause of Death: Old age, dear
•	Likes: Crosswords, antiques, fashion, romance novels, my former work as an engineer.
•	Dislikes: Retirement was not kind, and I hate those feathered fiends.
"

[node name="Page5" type="RichTextLabel" parent="DossierPanel" groups=["dossierPages"]]
visible = false
layout_mode = 0
offset_left = 96.0
offset_top = 74.0
offset_right = 1131.0
offset_bottom = 608.0
theme_override_font_sizes/normal_font_size = 40
text = "Franklyn
•	Age of Death: 40
•	Cause of Death: Electrocution
•	Likes: Videogames and the lottery helped me relieve stress. Also, I was a gym rat. Still am.
•	Dislikes: Cables (obviously), sweets, sugary drinks and jazz music. Don’t ask.
"

[node name="Page6" type="RichTextLabel" parent="DossierPanel" groups=["dossierPages"]]
visible = false
layout_mode = 0
offset_left = 96.0
offset_top = 74.0
offset_right = 1131.0
offset_bottom = 608.0
theme_override_font_sizes/normal_font_size = 40
text = "Gordon
•	Age of Death: 27
•	Cause of Death: Didn’t see the car
•	Likes: Videogames, rock and roll, cooking and baking.
•	Dislikes: Cars, ghosts (but not the nice ones), and maths.
"

[node name="Page7" type="RichTextLabel" parent="DossierPanel" groups=["dossierPages"]]
