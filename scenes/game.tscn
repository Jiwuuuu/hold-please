theme_override_font_sizes/normal_font_size = 32
text = "Annabeth
•	Age of Death: A lady never tells.
•	Cause of Death: Heart failure.
•	Likes: Fine wine, gossip and jazz music.
•	Dislikes: Pets and cold weather. Also, I never understood people who drink tea.
"

[node name="Page1" type="RichTextLabel" parent="DossierPanel" unique_id=816419343 groups=["dossierPages"]]
visible = false
layout_mode = 0
offset_left = 60.0
offset_top = 70.0
offset_right = 940.0
offset_bottom = 520.0
theme_override_colors/default_color = Color(0.2, 0.15, 0.1, 1)
theme_override_font_sizes/normal_font_size = 32
text = "Bryan
•	Age of Death: 52
•	Cause of Death: Severe alcohol poisoning.
•	Likes: Booze, chess and football. And my family, of course!
•	Dislikes: Rock and roll and those blasted politics.

"

[node name="Page2" type="RichTextLabel" parent="DossierPanel" unique_id=1113307161 groups=["dossierPages"]]
