offset_bottom = 608.0
theme_override_font_sizes/normal_font_size = 40
text = "Henri
•	Age of Death: 65
•	Cause of Death: Lycanthropy
•	Likes: Deep conversations, fine art and the full moon.
•	Dislikes: Nightmares, talking about my father, loud noises, and silver paraphernalia.
"

[node name="Page8" type="RichTextLabel" parent="DossierPanel" groups=["dossierPages"]]
