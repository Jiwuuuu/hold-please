theme_override_font_sizes/normal_font_size = 32
text = "Charles
•	Age of Death: 81
•	Cause of Death: Severe concussion
•	Likes: Checkers, charity work, and my pet parrot.
•	Dislikes: Classical music, opera, ballet and all that. And oranges! Nasty oranges!
"

[node name="Page3" type="RichTextLabel" parent="DossierPanel" unique_id=1607637350 groups=["dossierPages"]]
