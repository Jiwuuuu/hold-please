text = "Annabeth
•	Age of Death: A lady never tells.
•	Cause of Death: Heart failure.
•	Likes: Fine wine, gossip and jazz music.
•	Dislikes: Pets and cold weather. Also, I never understood people who drink tea.
"

[node name="Page1" type="RichTextLabel" parent="DossierPanel" unique_id=268913674 groups=["dossierPages"]]
visible = false
layout_mode = 0
